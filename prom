async function cargarTablets() {
    const titulo = document.getElementById('titulo-reporte');
    const cuerpo = document.getElementById('tabla-cuerpo');
    const cabecera = document.querySelector('thead');
    
    titulo.innerText = "Cargando Listado de Tablets...";
    
    // 1. Agregamos las cabeceras de Cantidad y Ubicación
    cabecera.innerHTML = `
        <tr>
            <th>ID</th>
            <th>Modelo / Serie</th>
            <th>Descripción</th>
            <th>Cantidad</th>
            <th>Estado</th>
            <th>Ubicación</th>
        </tr>
    `;

    try {
        const respuesta = await fetch('/api/tablets');
        const datos = await respuesta.json();

        cuerpo.innerHTML = '';
        datos.forEach(tablet => {
            // 2. Insertamos las nuevas celdas en la fila
            const fila = `
                <tr>
                    <td>${tablet.id_articulo}</td>
                    <td><strong>${tablet.modelo}</strong><br><small class="text-muted">${tablet.num_serie}</small></td>
                    <td>${tablet.descripcion}</td>
                    <td>1</td> <td>
                        <span class="badge ${tablet.estado === 'Disponible' ? 'bg-success' : 'bg-primary'}">
                            ${tablet.estado}
                        </span>
                    </td>
                    <td>${tablet.ubicacion || 'Sin asignar'}</td>
                </tr>
            `;
            cuerpo.innerHTML += fila;
        });
        
        titulo.innerText = "Inventario General de Tablets";

    } catch (error) {
        console.error("Error:", error);
        cuerpo.innerHTML = '<tr><td colspan="6" class="text-center text-danger">Error al cargar tablets</td></tr>';
    }


















    async obtenerTodas() {
    const sql = `
        SELECT 
            p.id_articulo, 
            ds.num_serie, 
            ds.modelo, 
            p.descripcion, 
            COALESCE(m.estado, 'Disponible') as estado,
            COALESCE(m.ubicacion, 'No especificada') as ubicacion -- Traemos la ubicación del último movimiento
        FROM producto p
        INNER JOIN detalle_serializado ds ON p.id_articulo = ds.id_articulo
        LEFT JOIN (
            SELECT m1.id_articulo, m1.estado, m1.ubicacion 
            FROM movimiento m1
            WHERE m1.id_movimiento = (
                SELECT MAX(m2.id_movimiento) 
                FROM movimiento m2 
                WHERE m2.id_articulo = m1.id_articulo
            )
        ) m ON p.id_articulo = m.id_articulo
        WHERE p.categoria = 'Tablet'
    `;

    try {
        const rows = await pool.query(sql);
        return rows; // Retorna los datos con la nueva columna
    } catch (error) {
        console.error("Error en TabletRepository:", error);
        throw error;
    }
}
